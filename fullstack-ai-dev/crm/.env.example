# Copy this file to .env.local and fill in your values
# Get these from: supabase.com -> your project -> Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Get this from: console.anthropic.com -> API Keys
# IMPORTANT: No NEXT_PUBLIC_ prefix — server only
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Demo credentials (for the reference/demo deployment only)
NEXT_PUBLIC_DEMO_EMAIL=demo@mycrm.app
NEXT_PUBLIC_DEMO_PASSWORD=demo1234
